  tree,
  data,
  Q = NULL,
  estimate_Q = FALSE,
  lambda_sigma,
  expected_background = NULL,
  root_prior = "fitzjohn",
  q_prior = "diffuse",
  smoothing = NULL,
  covariates = NULL,
  ngen = 10000,
  burn_in = 2000,
  thin = 10,
  tau_init = 0.3,
  target_acceptance = 0.3,
  seed = NULL
)
}
