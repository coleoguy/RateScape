\examples{
\dontrun{
  # Step 1: Fit the model
  Q <- makeQ(model = "mk", k = 2)
  fit <- fitRateScape(tree, data, Q, lambda_sigma = 1.0, ngen = 50000)

  # Step 2: Run posterior predictive checks
  ppc <- posteriorPredictive(fit, data, nsim = 500)

  # Step 3: Look at the results
  print(ppc)
  # Output will show something like:
  #   Statistic       Observed  Sim.Mean  P-value  Adequate
  #   transitions     12.000    11.430    0.452    TRUE
  #   entropy          0.693     0.701    0.538    TRUE
  #   consistency      0.800     0.782    0.410    TRUE
  #   rate_dispersion  0.120     0.098    0.872    TRUE
  #   max_clade_freq   0.650     0.640    0.490    TRUE
  #
  # All p-values near 0.5 = model fits well!
  # If "transitions" had p-value = 0.01, it would mean the model
  # underestimates how many state changes occurred.

  # Step 4: Visualize the checks
  plot(ppc)
  # Shows histograms of simulated values with the observed value
  # marked as a vertical line. If the line is in the middle of the
  # histogram, the model is doing well for that statistic.
}
