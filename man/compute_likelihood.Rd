}
\value{
A single number: the (log-)likelihood of the data given the tree, Q matrix,
and branch rates. Higher values (less negative for log-likelihoods) indicate
a better fit.
}
\examples{
\dontrun{
  library(ape)
  tree <- rcoal(20)
  Q <- makeQ(model = "mk", k = 2)
  states <- sample(0:1, 20, replace = TRUE)

  # Likelihood under homogeneous rates (all branches at rate 1)
  r_homo <- rep(1.0, nrow(tree$edge))
  ll_homo <- compute_likelihood(tree, states, Q, r_homo)

  # Likelihood if we double the rate on the first 5 branches
  r_het <- r_homo
  r_het[1:5] <- 2.0
  ll_het <- compute_likelihood(tree, states, Q, r_het)

  # Compare: which fits better?
  cat("Homogeneous loglik:", ll_homo, "\n")
